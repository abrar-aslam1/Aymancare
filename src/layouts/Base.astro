// Redirect legacy hash-routed URLs (aymancare.com/#page-x) to their new pages
(function(){
  var map = {"page-home":"/","page-services":"/services/","page-about":"/about/","page-locations":"/locations/","page-contact":"/contact/","page-location-dallas":"/locations/dallas/","page-location-nrh":"/locations/north-richland-hills/","page-location-mesquite":"/locations/mesquite/","page-location-valley":"/locations/valley-ranch/","page-primary-care":"/services/primary-care/","page-walk-in":"/services/walk-in-urgent-care/","page-pediatric-care":"/services/pediatric-care/","page-flu":"/services/flu-treatment/","page-allergy":"/services/allergy-treatment/","page-weight-loss":"/services/weight-loss/","page-covid":"/services/covid-19-testing/","page-blog":"/blog/","page-book-online":"/book-online/","page-insurance":"/insurance/","page-thank-you":"/thank-you/","page-privacy":"/privacy/","page-heart-month":"/blog/heart-health-month/","page-why-primary-care":"/blog/why-primary-care/","page-annual-physical":"/blog/annual-physical/","page-cold-flu-covid":"/blog/cold-flu-or-covid/","page-dallas-allergy":"/blog/dallas-allergy-guide/","page-when-to-bring-child-in":"/blog/when-to-bring-child-in/","page-sustainable-weight-loss":"/blog/sustainable-weight-loss/","page-insurance-benefits":"/blog/insurance-benefits/","page-er-vs-urgent-care":"/blog/er-vs-urgent-care/","page-five-habits":"/blog/five-healthy-habits/","page-four-clinics":"/blog/four-clinics-one-team/"};
  function go() {
    var h = location.hash.replace('#', '');
    if (map[h] && map[h] !== location.pathname) location.replace(map[h]);
  }
  go();
  window.addEventListener('hashchange', go);
})();
</script>
