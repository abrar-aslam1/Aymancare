---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Urgent Care &amp; Primary Care in Dallas, TX — N Buckner Blvd | AymanCare"
  description="Walk-in urgent care and primary care on N Buckner Blvd in East Dallas. Serving White Rock, Lakewood and Casa Linda. Call (214) 328-7400 — walk-ins welcome."
>
  <Fragment slot="head">
  <script type="application/ld+json" is:inline set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"MedicalClinic\",\"@id\":\"https://aymancare.com/locations/dallas/#clinic\",\"name\":\"AymanCare — Dallas\",\"parentOrganization\":{\"@id\":\"https://aymancare.com/#organization\"},\"url\":\"https://aymancare.com/locations/dallas/\",\"telephone\":\"+12143287400\",\"image\":\"https://aymancare.com/images/clinic-exterior.jpeg\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"N Buckner Blvd\",\"addressLocality\":\"Dallas\",\"addressRegion\":\"TX\",\"postalCode\":\"75218\",\"addressCountry\":\"US\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":32.8296,\"longitude\":-96.6891},\"openingHoursSpecification\":[{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"],\"opens\":\"09:00\",\"closes\":\"16:00\"}],\"medicalSpecialty\":[\"PrimaryCare\",\"Pediatric\"],\"sameAs\":[\"https://share.google/r68RxahU9wK78SchP\"]}"} />
  <script type="application/ld+json" is:inline set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://aymancare.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Locations\",\"item\":\"https://aymancare.com/locations/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Dallas\",\"item\":\"https://aymancare.com/locations/dallas/\"}]}"} />
  </Fragment>
<section class="page-hero">
  <div class="breadcrumbs fade-in">
    <a href="/">Home</a><span class="sep">✦</span><a href="/locations/">Locations</a><span class="sep">✦</span><span>Dallas</span>
  </div>
  <div class="loc-d-hero-grid">
    <div>
      <div class="loc-d-pin-label fade-in">
        <div class="loc-d-pin-big">
          <svg aria-hidden="true" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <span class="overline">◆ East Dallas</span>
      </div>
      <h1 class="page-title fade-in" style="margin-bottom: 20px;"><em>Dallas</em></h1>
      <p class="loc-d-addr fade-in">N Buckner Blvd,<br>Dallas, TX 75218</p>
      <div class="fade-in" style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/book-online/" class="btn btn-primary">Book appointment →</a>
        <a href="https://www.google.com/maps/search/?api=1&query=AymanCare+Dallas+N+Buckner+Blvd+Dallas+TX+75218" target="_blank" rel="noopener" class="btn btn-outline">Get directions ↗</a>
      </div>
    </div>

    <div class="loc-d-side fade-in">
      <span class="overline" style="margin-bottom: 16px; display: block;">✦ At this location</span>
      <p>Our flagship Dallas location offers full primary and urgent care services — walk-ins welcome — for individuals and families across East Dallas.</p>
      <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <span class="pill pill-accent">Walk-ins</span>
        <span class="pill">Pediatrics</span>
        <span class="pill pill-outline">Occupational medicine</span>
      </div>
    </div>
  </div>
</section>

<section class="section" style="padding-top: 0;">
  <div class="loc-body">
    <div class="map-card fade-in">
      <div>
        <div class="l">✦ Location</div>
        <h3>Find us in <em>Dallas.</em></h3>
      </div>
      <div class="map-pin-viz">
        <svg aria-hidden="true" viewBox="0 0 300 180">
          <defs>
            <pattern id="mp-grid-dallas" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M 20 0 L 0 0 0 20" stroke="white" stroke-width="0.3" opacity="0.15" fill="none"/>
            </pattern>
          </defs>
          <rect width="300" height="180" fill="url(#mp-grid-dallas)"/>
          <path d="M 0 90 Q 80 70, 150 90 Q 220 110, 300 90" stroke="white" stroke-width="1.5" opacity="0.25" fill="none"/>
          <path d="M 150 0 Q 140 80, 150 180" stroke="white" stroke-width="1" opacity="0.2" fill="none"/>
          <circle cx="150" cy="90" r="30" fill="#e89056" opacity="0.3">
            <animate attributeName="r" values="30;42;30" dur="2.5s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.3;0.08;0.3" dur="2.5s" repeatCount="indefinite"/>
          </circle>
          <circle cx="150" cy="90" r="18" fill="#e89056"/>
          <path d="M150 80 L150 95 M150 95 L145 100 M150 95 L155 100" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <circle cx="150" cy="86" r="3" fill="white"/>
        </svg>
      </div>
      <div>
        <a href="https://www.google.com/maps/search/?api=1&query=AymanCare+Dallas+N+Buckner+Blvd+Dallas+TX+75218" target="_blank" rel="noopener" class="btn btn-accent">Open in Google Maps →</a>
      </div>
    </div>

    <div class="info-stack">
      <div class="info-card fade-in">
        <div class="l">✦ Call</div>
        <a class="big-num" href="tel:+12143287400">(214) 328-7400</a>
        <p>Speak with our team to schedule, ask questions, or get directions.</p>
      </div>
      <div class="info-card fade-in">
        <div class="l">✦ Hours</div>
        <h4>Opening <em>hours</em></h4>
        <div class="hours-row"><span class="day">Mon – Fri</span><span class="time">9AM – 4PM</span></div>
        <div class="hours-row"><span class="day">Saturday</span><span class="time" style="color: var(--ink-muted);">Closed</span></div>
        <div class="hours-row"><span class="day">Sunday</span><span class="time" style="color: var(--ink-muted);">Closed</span></div>
        <p style="margin-top: 12px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;">Holiday hours may vary. Call ahead.</p>
      </div>
      <div class="info-card warm fade-in">
        <div class="l">✦ Insurance</div>
        <h4>Most <em>plans</em> accepted</h4>
        <p>Medicare, Tricare, Aetna, BlueCross, Cigna, UnitedHealth, and more. Call to confirm your plan.</p>
      </div>
    </div>
  </div>

  <div class="svc-at-loc">
    <div class="section-header" style="margin-bottom: 0; padding-bottom: 0; border-bottom: none;">
      <div>
        <span class="overline fade-in" style="margin-bottom: 16px; display: block;">◆ Offered at this location</span>
        <h2 class="section-title fade-in" style="font-size: clamp(32px, 4vw, 48px);">Full-service<br>care, <em>on-site.</em></h2>
      </div>
    </div>

    <div class="svc-at-loc-grid">
      <a href="/services/primary-care/" class="svc-mini-card fade-in">
        <div class="ic"><svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
        <h5><em>Primary</em> Care</h5>
      </a>
      <a href="/services/walk-in-urgent-care/" class="svc-mini-card fade-in">
        <div class="ic"><svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
        <h5><em>Walk-in</em></h5>
      </a>
      <a href="/services/pediatric-care/" class="svc-mini-card fade-in">
        <div class="ic"><svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg></div>
        <h5><em>Pediatric</em></h5>
      </a>
      <a href="/services/flu-treatment/" class="svc-mini-card fade-in">
        <div class="ic"><svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20"/></svg></div>
        <h5><em>Flu</em></h5>
      </a>
      <a href="/services/allergy-treatment/" class="svc-mini-card fade-in">
        <div class="ic"><svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3 7h7l-6 4 3 7-7-5-7 5 3-7-6-4h7z"/></svg></div>
        <h5><em>Allergy</em></h5>
      </a>
      <a href="/services/weight-loss/" class="svc-mini-card fade-in">
        <div class="ic"><svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg></div>
        <h5><em>Weight</em> Loss</h5>
      </a>
      <a href="/services/walk-in-urgent-care/" class="svc-mini-card fade-in">
        <div class="ic"><svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg></div>
        <h5><em>COVID</em> Testing</h5>
      </a>
      <a href="/services/" class="svc-mini-card dark fade-in">
        <div class="ic"><svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></div>
        <h5>See <em>all</em></h5>
      </a>
    </div>
  </div>

  <div class="neighborhood-band fade-in">
    <div>
      <span class="overline" style="color: var(--accent); margin-bottom: 20px; display: block;">✦ Proud to serve</span>
      <h2>Part of the <em>White Rock Lake</em> community.</h2>
    </div>
    <div>
      <p>We serve families across East Dallas — from White Rock and Lakewood to Forest Hills and Casa Linda. Close to home, close to where you live life.</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/book-online/" class="btn btn-accent">Book appointment →</a>
        <a href="tel:+12143287400" class="btn btn-ghost">Call (214) 328-7400</a>
      </div>
    </div>
  </div>

  <div class="forms-section fade-in">
    <div class="forms-section-inner">
      <div class="forms-header">
        <span class="overline">◆ New patient paperwork</span>
        <h2>Download your <em>forms</em> before your visit.</h2>
        <p>Complete these at home and bring them in — or email the completed forms to <a href="mailto:aymancare2019@gmail.com">aymancare2019@gmail.com</a>.</p>
      </div>
      <div class="forms-grid">
        <a href="https://irp.cdn-website.com/de29bafa/files/uploaded/Patient%20Registration%20Form%20%28Rev%20101222%29.pdf" target="_blank" rel="noopener" class="pdf-card">
          <div class="form-icon"><svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg></div>
          <div>
            <div class="form-name">Patient Registration</div>
            <div class="form-lang">English · PDF</div>
          </div>
          <span class="form-dl">Download ↓</span>
        </a>
        <a href="https://irp.cdn-website.com/de29bafa/files/uploaded/Patient%20Registration%20Form%20%28Rev%2092022%29SPANISH.pdf" target="_blank" rel="noopener" class="pdf-card">
          <div class="form-icon"><svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg></div>
          <div>
            <div class="form-name">Patient Registration</div>
            <div class="form-lang">Spanish · PDF</div>
          </div>
          <span class="form-dl">Download ↓</span>
        </a>
        <a href="https://irp.cdn-website.com/de29bafa/files/uploaded/Authorization%20to%20Release%20Medical%20%20Records%20-%20Aymancare.pdf" target="_blank" rel="noopener" class="pdf-card">
          <div class="form-icon"><svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg></div>
          <div>
            <div class="form-name">Medical Release Form</div>
            <div class="form-lang">Authorization to Release Records · PDF</div>
          </div>
          <span class="form-dl">Download ↓</span>
        </a>
      </div>
    </div>
  </div>

  <div class="other-locs-section">
    <span class="overline fade-in" style="margin-bottom: 16px; display: block;">◆ Other locations</span>
    <h2 class="section-title fade-in" style="font-size: clamp(32px, 4vw, 52px);">Four clinics. <em>One</em> team.</h2>
    <div class="other-grid"><a href="/locations/north-richland-hills/" class="other-card fade-in">
          <h5>North <em>Richland Hills</em></h5>
          <p>8208 Bedford Euless Rd, · North Richland Hills, TX</p>
        </a><a href="/locations/mesquite/" class="other-card fade-in">
          <h5><em>Mesquite</em></h5>
          <p>3400 I-30 E, · Mesquite, TX 75150</p>
        </a><a href="/locations/valley-ranch/" class="other-card fade-in">
          <h5>Valley <em>Ranch</em></h5>
          <p>10009 N MacArthur Blvd, · Irving, TX 75063</p>
        </a></div>
  </div>
</section>
</Base>
