---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Contact AymanCare — Phone Numbers, Addresses &amp; Hours"
  description="Call or visit any of our four Dallas–Fort Worth clinics. Phone numbers, addresses and opening hours for AymanCare Dallas, NRH, Mesquite and Valley Ranch."
>
  <Fragment slot="head">
  <script type="application/ld+json" is:inline set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://aymancare.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Contact\",\"item\":\"https://aymancare.com/contact/\"}]}"} />
  </Fragment>
<section class="page-hero">
  <div class="breadcrumbs fade-in">
    <a href="/">Home</a><span class="sep">✦</span><span>Contact</span>
  </div>
  <h1 class="page-title fade-in">Get in <em>touch.</em></h1>
  <p class="page-subtitle fade-in">Have a question? AymanCare is here to help. Send us a message and we'll be in touch — usually within a few business hours. For urgent medical needs, please call or walk in.</p>
</section>

<section class="section" style="padding-top: 0;">
  <div class="contact-grid">
    <div class="form-card fade-in">
      <h2>Give us a <em>call.</em></h2>
      <p class="sub">The fastest way to reach us is by phone. Call your nearest location directly — our team will help you schedule or answer any questions.</p>

      <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 28px;">
        <a href="tel:+12143287400" style="display: flex; align-items: center; gap: 16px; padding: 20px 24px; background: var(--bg-soft); border-radius: 12px; text-decoration: none; color: inherit; border: 1px solid var(--border); transition: border-color 0.2s;">
          <div style="width: 40px; height: 40px; background: var(--blue); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.21 12 19.79 19.79 0 0 1 1.14 3.37 2 2 0 0 1 3.11 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 4px;">Dallas — N Buckner Blvd</div>
            <div style="font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--blue); letter-spacing: -0.02em;">(214) 328-7400</div>
          </div>
        </a>
        <a href="tel:+18175815959" style="display: flex; align-items: center; gap: 16px; padding: 20px 24px; background: var(--bg-soft); border-radius: 12px; text-decoration: none; color: inherit; border: 1px solid var(--border); transition: border-color 0.2s;">
          <div style="width: 40px; height: 40px; background: var(--blue); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.21 12 19.79 19.79 0 0 1 1.14 3.37 2 2 0 0 1 3.11 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 4px;">North Richland Hills — Bedford Euless Rd</div>
            <div style="font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--blue); letter-spacing: -0.02em;">(817) 581-5959</div>
          </div>
        </a>
        <a href="tel:+19722889747" style="display: flex; align-items: center; gap: 16px; padding: 20px 24px; background: var(--bg-soft); border-radius: 12px; text-decoration: none; color: inherit; border: 1px solid var(--border); transition: border-color 0.2s;">
          <div style="width: 40px; height: 40px; background: var(--blue); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.21 12 19.79 19.79 0 0 1 1.14 3.37 2 2 0 0 1 3.11 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 4px;">Mesquite — I-30 E</div>
            <div style="font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--blue); letter-spacing: -0.02em;">(972) 288-9747</div>
          </div>
        </a>
        <a href="tel:+14699137043" style="display: flex; align-items: center; gap: 16px; padding: 20px 24px; background: var(--bg-soft); border-radius: 12px; text-decoration: none; color: inherit; border: 1px solid var(--border); transition: border-color 0.2s;">
          <div style="width: 40px; height: 40px; background: var(--blue); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.21 12 19.79 19.79 0 0 1 1.14 3.37 2 2 0 0 1 3.11 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 4px;">Valley Ranch — MacArthur Blvd, Irving</div>
            <div style="font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--blue); letter-spacing: -0.02em;">(469) 913-7043</div>
          </div>
        </a>
      </div>

      <p style="margin-top: 24px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-soft);">
        ✦ Walk-ins welcome at all four locations · No appointment needed for urgent care
      </p>
    </div>

    <div class="contact-side">
      <a href="/contact/" class="side-card fade-in">
        <div class="icon">
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <h3><em>Call</em> us</h3>
        <p>Mon–Sat · See locations for individual hours.</p>
        <span class="link-big">View all numbers →</span>
      </a>

      <a href="/locations/" class="side-card fade-in">
        <div class="icon">
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3><em>Walk</em> in</h3>
        <p>All four locations accept walk-ins. No appointment needed for urgent care.</p>
        <span class="arrow-link">Find a location ↗</span>
      </a>

      <a href="#book" class="side-card dark fade-in">
        <div class="icon">
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h3><em>Book</em> online</h3>
        <p>Choose your location and preferred time — most slots available same-day.</p>
        <span class="arrow-link">Schedule below ↓</span>
      </a>
    </div>
  </div>
</section>

<!-- BOOKING FLOW -->
<section class="book-section" id="book">
  <div class="book-grid">
    <div class="book-card fade-in">
      <div class="steps">
        <div class="step active">1 · Service</div>
        <div class="step active">2 · Location</div>
        <div class="step active">3 · Time</div>
        <div class="step">4 · Details</div>
      </div>

      <h2>Book your <em>appointment.</em></h2>
      <p>Same-day appointments often available. Walk-ins welcome — no appointment required for urgent care.</p>

      <h3><em>01.</em> Choose a service</h3>
      <div class="opt-grid" id="booking-service-grid">
        <div class="opt selected"><h4>Primary care</h4><p>Annual exam, checkup, chronic care</p></div>
        <div class="opt"><h4>Walk-in urgent</h4><p>Same-day, no appointment</p></div>
        <div class="opt"><h4>Pediatric visit</h4><p>Child checkup or sick visit</p></div>
        <div class="opt"><h4>Something else</h4><p>Allergy, weight loss, more</p></div>
      </div>

      <h3><em>02.</em> Choose a location</h3>
      <div class="opt-grid" id="booking-location-grid">
        <div class="opt selected"><h4>Dallas</h4><p>N Buckner Blvd</p></div>
        <div class="opt"><h4>North Richland Hills</h4><p>Bedford Euless Rd</p></div>
        <div class="opt"><h4>Mesquite</h4><p>I-30 E</p></div>
        <div class="opt"><h4>Valley Ranch</h4><p>MacArthur Blvd, Irving</p></div>
      </div>

      <h3><em>03.</em> Pick a time <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-muted); letter-spacing: 0.14em; text-transform: uppercase; margin-left: 8px; font-weight: 500;">Today</span></h3>
      <div class="time-grid" id="booking-time-grid">
        <div class="time">9:00 AM</div>
        <div class="time">9:30 AM</div>
        <div class="time">10:15 AM</div>
        <div class="time selected">2:15 PM</div>
        <div class="time">2:45 PM</div>
        <div class="time">3:30 PM</div>
        <div class="time">4:00 PM</div>
        <div class="time">4:45 PM</div>
      </div>

      <h3><em>04.</em> Your details</h3>
      <p style="font-size: 14px; color: var(--ink-soft); margin-bottom: 20px;">Fill in your contact info and any notes on the next step.</p>
    </div>

    <div class="summary-card fade-in">
      <div class="sub">✦ Your appointment</div>
      <h3 id="sum-service"><em>Primary</em> care visit</h3>

      <div class="sum-row">
        <span class="k">Location</span>
        <span class="v" id="sum-location">Dallas</span>
      </div>
      <div class="sum-row">
        <span class="k">Date</span>
        <span class="v">Today</span>
      </div>
      <div class="sum-row">
        <span class="k">Time</span>
        <span class="v" id="sum-time">2:15 PM</span>
      </div>
      <div class="sum-row">
        <span class="k">Physician</span>
        <span class="v">Dr. A. Khan</span>
      </div>
      <div class="sum-row">
        <span class="k">Insurance</span>
        <span class="v" style="font-size: 14px; color: var(--accent);">✓ Most accepted</span>
      </div>

      <button type="button" id="confirm-booking-btn">Confirm booking →</button>

      <div style="margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.15);">
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-bottom: 10px;">Prefer to call?</div>
        <a href="/contact/" style="font-family: 'DM Serif Display', serif; font-weight: 400; font-size: 26px; color: var(--accent); text-decoration: none; letter-spacing: -0.02em;">View all locations →</a>
      </div>
    </div>
  </div>
</section>
</Base>
