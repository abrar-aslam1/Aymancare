---
import Base from '../layouts/Base.astro';
---
<Base
  title="AymanCare — Primary &amp; Urgent Care in Dallas–Fort Worth"
  description="Need a doctor in Dallas–Fort Worth? AymanCare delivers same-day primary care, urgent care &amp; pediatrics at 4 neighborhood clinics. Walk-ins always welcome."
>
  <Fragment slot="head">
  <script type="application/ld+json" is:inline set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"MedicalClinic\",\"@id\":\"https://aymancare.com/locations/dallas/#clinic\",\"name\":\"AymanCare — Dallas\",\"parentOrganization\":{\"@id\":\"https://aymancare.com/#organization\"},\"url\":\"https://aymancare.com/locations/dallas/\",\"telephone\":\"+12143287400\",\"image\":\"https://aymancare.com/images/clinic-exterior.jpeg\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"N Buckner Blvd\",\"addressLocality\":\"Dallas\",\"addressRegion\":\"TX\",\"postalCode\":\"75218\",\"addressCountry\":\"US\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":32.8296,\"longitude\":-96.6891},\"openingHoursSpecification\":[{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"],\"opens\":\"09:00\",\"closes\":\"16:00\"}],\"medicalSpecialty\":[\"PrimaryCare\",\"Pediatric\"],\"sameAs\":[\"https://share.google/r68RxahU9wK78SchP\"]}"} />
  <script type="application/ld+json" is:inline set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"MedicalClinic\",\"@id\":\"https://aymancare.com/locations/north-richland-hills/#clinic\",\"name\":\"AymanCare — North Richland Hills\",\"parentOrganization\":{\"@id\":\"https://aymancare.com/#organization\"},\"url\":\"https://aymancare.com/locations/north-richland-hills/\",\"telephone\":\"+18175815959\",\"image\":\"https://aymancare.com/images/clinic-exterior.jpeg\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"8208 Bedford Euless Rd\",\"addressLocality\":\"North Richland Hills\",\"addressRegion\":\"TX\",\"postalCode\":\"76180\",\"addressCountry\":\"US\"},\"openingHoursSpecification\":[{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"],\"opens\":\"09:00\",\"closes\":\"17:00\"}],\"medicalSpecialty\":[\"PrimaryCare\",\"Pediatric\"],\"sameAs\":[\"https://share.google/WqfsdISLFMnBLnNVY\"]}"} />
  <script type="application/ld+json" is:inline set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"MedicalClinic\",\"@id\":\"https://aymancare.com/locations/mesquite/#clinic\",\"name\":\"AymanCare — Mesquite\",\"parentOrganization\":{\"@id\":\"https://aymancare.com/#organization\"},\"url\":\"https://aymancare.com/locations/mesquite/\",\"telephone\":\"+19722889747\",\"image\":\"https://aymancare.com/images/clinic-exterior.jpeg\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"3400 I-30 E\",\"addressLocality\":\"Mesquite\",\"addressRegion\":\"TX\",\"postalCode\":\"75150\",\"addressCountry\":\"US\"},\"openingHoursSpecification\":[{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"],\"opens\":\"09:00\",\"closes\":\"17:00\"}],\"medicalSpecialty\":[\"PrimaryCare\",\"Pediatric\"],\"sameAs\":[\"https://share.google/xzjU1sVIsuyLOqynI\"]}"} />
  <script type="application/ld+json" is:inline set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"MedicalClinic\",\"@id\":\"https://aymancare.com/locations/valley-ranch/#clinic\",\"name\":\"AymanCare — Valley Ranch\",\"parentOrganization\":{\"@id\":\"https://aymancare.com/#organization\"},\"url\":\"https://aymancare.com/locations/valley-ranch/\",\"telephone\":\"+14699137043\",\"image\":\"https://aymancare.com/images/clinic-exterior.jpeg\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"10009 N MacArthur Blvd\",\"addressLocality\":\"Irving\",\"addressRegion\":\"TX\",\"postalCode\":\"75063\",\"addressCountry\":\"US\"},\"openingHoursSpecification\":[{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"],\"opens\":\"09:00\",\"closes\":\"16:00\"}],\"medicalSpecialty\":[\"PrimaryCare\",\"Pediatric\"],\"sameAs\":[\"https://share.google/O7Pri9B62mYRXkt9E\"]}"} />
  </Fragment>
<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow fade-in">Primary + Urgent Care · Dallas, TX</div>
      <h1 class="hero-title fade-in">We care about<br><span class="underline"><em>you.</em></span></h1>
      <p class="hero-lede fade-in">
        Compassionate, board-certified family medicine across four Dallas-area locations. Primary care, urgent care, and pediatrics — with the warmth of a neighborhood clinic and the expertise your family deserves.
      </p>
      <div class="hero-ctas fade-in">
        <a href="/book-online/" class="btn btn-primary">
          Make an appointment
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="/services/" class="btn btn-outline">Our services</a>
      </div>

      <div class="hero-trust fade-in">
        <div class="trust-item">
          <span class="trust-num">04</span>
          <span class="trust-label">Dallas-area locations</span>
        </div>
        <div class="trust-item">
          <span class="trust-num">10<em>+</em></span>
          <span class="trust-label">Years serving DFW</span>
        </div>
        <div class="trust-item">
          <span class="trust-num">4.8<em>★</em></span>
          <span class="trust-label">Google rating</span>
        </div>
      </div>
    </div>

    <div class="hero-visual fade-in">
      <div class="hero-img-main">
        <img src="/images/staff-photo.jpg" alt="Dr. Ajaz Khan, MD - AymanCare" fetchpriority="high" width="800" height="1000">
      </div>
      <div class="hero-float-card card-rating">
        <div class="rating-num">4.8</div>
        <div>
          <div class="rating-stars">★★★★★</div>
          <div class="rating-label">Google Reviews</div>
        </div>
      </div>
      <div class="hero-float-card card-available">
        <div class="avail-icon">
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="avail-text">
          <div class="v">Walk-ins Welcome</div>
          <div class="k">No appointment needed</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- INSURANCE STRIP -->
<div class="trust-strip">
  <div class="trust-strip-inner">
    <div class="trust-strip-label">Most major<br>insurances accepted</div>
    <div class="trust-strip-logos">
      <span>Medicare</span>
      <span>Tricare</span>
      <span>Aetna</span>
      <span>BlueCross</span>
      <span>Cigna</span>
      <span>UnitedHealth</span>
      <span>Humana</span>
    </div>
  </div>
</div>

<!-- SERVICES -->
<section class="section" id="services">
  <div class="section-header">
    <div>
      <span class="overline fade-in" style="margin-bottom: 16px; display: block;">◆ Our Services</span>
      <h2 class="section-title fade-in">Comprehensive care<br>for <em>every stage.</em></h2>
    </div>
    <p class="section-subtitle fade-in">
      From annual physicals and pediatric wellness visits to same-day urgent care — a full spectrum of services, all under one roof.
    </p>
  </div>

  <div class="services-grid">
    <a href="/services/primary-care/" class="svc-card fade-in feature feature-full">
      <div class="svc-card-img">
        <img src="/images/primary-care-clinic.jpg" alt="Primary care consultation" loading="lazy">
        <div class="svc-card-badge">Most requested</div>
      </div>
      <div class="svc-card-body">
        <h3><em>Primary</em> Care</h3>
        <p>Annual exams, preventive screenings, and chronic condition management — with a physician who knows your history and coordinates your care long-term. We accept Medicare, Tricare, and most major insurance.</p>
        <span class="svc-link">Learn more →</span>
      </div>
    </a>

    <a href="/services/walk-in-urgent-care/" class="svc-card fade-in">
      <div class="svc-card-img">
        <img src="/images/clinic-exterior.jpeg" alt="Walk-in urgent care" loading="lazy">
      </div>
      <div class="svc-card-body">
        <h3>Walk-In <em>Urgent</em></h3>
        <p>Same-day care for the unexpected — injuries, acute illness, COVID-19 testing, and everything between. No appointment needed.</p>
        <span class="svc-link">Learn more →</span>
      </div>
    </a>

    <a href="/services/pediatric-care/" class="svc-card fade-in">
      <div class="svc-card-img">
        <img src="/images/clinic-interior.jpg" alt="Pediatric care" loading="lazy">
      </div>
      <div class="svc-card-body">
        <h3><em>Pediatric</em> Care</h3>
        <p>Personalized, child-centered care at every stage — from newborn checkups to teen health.</p>
        <span class="svc-link">Learn more →</span>
      </div>
    </a>

    <a href="/services/flu-treatment/" class="svc-card fade-in">
      <div class="svc-card-img">
        <img src="/images/flu-care.jpg" alt="Flu & illness" loading="lazy">
      </div>
      <div class="svc-card-body">
        <h3>Flu & <em>Illness</em></h3>
        <p>Rapid testing and board-certified treatment so you can feel better, faster.</p>
        <span class="svc-link">Learn more →</span>
      </div>
    </a>

    <a href="/services/allergy-treatment/" class="svc-card fade-in">
      <div class="svc-card-img">
        <img src="/images/allergy-hero.jpg" alt="Allergy treatment" loading="lazy">
      </div>
      <div class="svc-card-body">
        <h3><em>Allergy</em> Treatment</h3>
        <p>Testing and personalized treatment plans for lasting relief from seasonal and environmental allergies.</p>
        <span class="svc-link">Learn more →</span>
      </div>
    </a>

    <a href="/services/weight-loss/" class="svc-card fade-in">
      <div class="svc-card-img">
        <img src="/images/weight-loss-hero.jpg" alt="Weight management" loading="lazy">
      </div>
      <div class="svc-card-body">
        <h3><em>Weight</em> Loss</h3>
        <p>Medically supervised programs focused on sustainable health, not quick fixes.</p>
        <span class="svc-link">Learn more →</span>
      </div>
    </a>

    <a href="/services/" class="svc-card svc-card-cta fade-in">
      <div class="svc-card-body svc-card-cta-body">
        <span class="overline" style="color: var(--accent); margin-bottom: 16px; display: block;">◆ And more</span>
        <h3>Explore all<br><em>services</em></h3>
        <p>From physicals and immunizations to chronic care management — we offer a full range of primary and urgent care services.</p>
        <span class="svc-link">View all services →</span>
      </div>
    </a>
  </div>
</section>

<!-- PROMISE -->
<section class="section-sm">
  <div class="promise">
    <span class="overline fade-in">◆ How we work</span>
    <h2 class="fade-in">Modern care, delivered<br>with <em>warmth.</em></h2>
    <div class="promise-steps">
      <div class="promise-step fade-in">
        <div class="promise-step-num">01 · Book</div>
        <h4>Easy <em>scheduling</em></h4>
        <p>Book online in under a minute, or walk in. Same-day appointments are the norm, not the exception.</p>
      </div>
      <div class="promise-step fade-in">
        <div class="promise-step-num">02 · Arrive</div>
        <h4>Seamless <em>intake</em></h4>
        <p>Complete paperwork digitally before you arrive. Most visits begin within 15 minutes.</p>
      </div>
      <div class="promise-step fade-in">
        <div class="promise-step-num">03 · Visit</div>
        <h4>Time with your <em>physician</em></h4>
        <p>Unhurried appointments with a board-certified provider who listens and explains clearly.</p>
      </div>
      <div class="promise-step fade-in">
        <div class="promise-step-num">04 · Follow-up</div>
        <h4>Coordinated <em>care</em></h4>
        <p>Labs, prescriptions, and referrals — all handled by the same team you already know.</p>
      </div>
    </div>
  </div>
</section>

<!-- DOCTOR -->
<section class="doctor-section" id="about">
  <div class="doctor-inner">
    <div class="doctor-img-frame fade-in">
      <img src="/images/staff-photo.jpg" alt="Dr. Ajaz Khan, MD">
      <div class="doctor-img-meta">
        <div class="l">✦ Medical Director</div>
        <div class="n">Ajaz Omer Khan, M.D.</div>
        <div class="c">American Board of Family Medicine</div>
      </div>
    </div>

    <div class="doctor-body">
      <span class="overline fade-in">◆ Meet Dr. Khan</span>
      <h2 class="fade-in">A physician dedicated<br>to your <em>whole health.</em></h2>
      <p class="fade-in">Dr. Ajaz Omer Khan is certified by the American Board of Family Medicine and continues to meet the requirements of his specialty board for ongoing learning and assessment — a commitment to lifelong learning that keeps his practice at the forefront of modern medicine.</p>
      <p class="fade-in">At AymanCare, we focus on the whole well-being by using data and technology to coordinate services and enhance care — because medicine, at its best, is deeply human.</p>
      <div class="doctor-chips fade-in">
        <span class="doctor-chip">ABFM Certified</span>
        <span class="doctor-chip accent">10+ years practicing</span>
        <span class="doctor-chip">All ages welcome</span>
      </div>
      <a href="/about/" class="btn btn-outline fade-in">Read more about Dr. Khan →</a>
    </div>
  </div>
</section>

<!-- TEAM -->
<section class="team-band">
  <div class="team-inner">
    <div class="team-copy">
      <span class="overline fade-in">◆ Our Team</span>
      <h2 class="fade-in">Behind every visit:<br>a <em>whole team.</em></h2>
      <p class="fade-in">
        AymanCare isn't built on one physician — it's built on a team. Nurses, medical assistants, and care coordinators who know your face, remember your family, and make every visit feel personal.
      </p>
      <p class="fade-in">
        Across our four Dallas-area clinics, the same standard of care follows you everywhere — because the people delivering it care about you as neighbors, not just patients.
      </p>
      <div style="display: flex; gap: 10px; margin-top: 32px; flex-wrap: wrap;" class="fade-in">
        <span class="pill">Board-certified</span>
        <span class="pill pill-accent">English / Spanish / Hindi / Urdu</span>
        <span class="pill pill-outline">Bilingual staff</span>
      </div>
    </div>

    <div class="team-photo-frame fade-in">
      <img src="/images/team-photo-v2.jpg" alt="The AymanCare team outside our clinic">
      <div class="team-photo-caption">
        <div class="l">✦ The AymanCare Team</div>
        <div class="t">Care you can count on — from people you recognize.</div>
      </div>
    </div>
  </div>
</section>

<!-- REVIEWS -->
<section class="section">
  <div class="reviews-head">
    <div>
      <span class="overline fade-in" style="margin-bottom: 16px; display: block;">◆ What patients say</span>
      <h2 class="section-title fade-in">Kindness meets<br><em>competence.</em></h2>
    </div>
    <div class="google-card fade-in">
      <div class="gg">
        <svg aria-hidden="true" width="36" height="36" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
          <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
          <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
          <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
        </svg>
      </div>
      <div class="num">4.8</div>
      <div>
        <div class="stars">★★★★★</div>
        <div class="label">Google · 200+ reviews</div>
      </div>
    </div>
  </div>

  <div class="reviews-grid">
    <div class="review-card fade-in">
      <div class="review-stars">★★★★★</div>
      <blockquote>"The professionals at AymanCare Medical Clinic are outstanding. I was seen promptly by my physician and treated with great respect. This is definitely a clinic I will return to — and I'm happy to refer my friends here."</blockquote>
      <div class="review-author">
        <div class="review-avatar">C</div>
        <div class="review-author-info">
          <div class="n">Charlie B.</div>
          <div class="meta">Patient since 2022</div>
        </div>
      </div>
    </div>

    <div class="review-card fade-in">
      <div class="review-stars">★★★★★</div>
      <blockquote>"You have an exceptional nursing team at your clinic, and everyone is always so friendly. Thank you for making every visit feel easy."</blockquote>
      <div class="review-author">
        <div class="review-avatar" style="background: var(--accent);">J</div>
        <div class="review-author-info">
          <div class="n">Jordan S.</div>
          <div class="meta">Pediatric family</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- LOCATIONS -->
<section class="section" id="locations">
  <div class="section-header">
    <div>
      <span class="overline fade-in" style="margin-bottom: 16px; display: block;">◆ Visit us</span>
      <h2 class="section-title fade-in">Four locations<br>across <em>DFW.</em></h2>
    </div>
    <p class="section-subtitle fade-in">
      Every clinic offers the same board-certified care and welcome. Find the AymanCare closest to you.
    </p>
  </div>

  <div class="locations-grid">
    <a href="/locations/dallas/" class="loc-card fade-in">
      <div class="loc-card-img">
        <img src="/images/loc-dallas.jpg" alt="AymanCare Dallas clinic" loading="lazy">
        <div class="loc-pin-badge">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
      </div>
      <div class="loc-card-body">
        <h3><em>Dallas</em></h3>
        <p class="addr">N Buckner Blvd<br>Dallas, TX 75218</p>
        <span class="loc-link">Visit location →</span>
      </div>
    </a>

    <a href="/locations/north-richland-hills/" class="loc-card fade-in">
      <div class="loc-card-img">
        <img src="/images/loc-nrh.jpg" alt="AymanCare North Richland Hills clinic" loading="lazy">
        <div class="loc-pin-badge">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
      </div>
      <div class="loc-card-body">
        <h3>North <em>Richland Hills</em></h3>
        <p class="addr">8208 Bedford Euless Rd<br>NRH, TX</p>
        <span class="loc-link">Visit location →</span>
      </div>
    </a>

    <a href="/locations/mesquite/" class="loc-card fade-in">
      <div class="loc-card-img">
        <img src="/images/loc-mesquite.jpg" alt="AymanCare Mesquite clinic" loading="lazy">
        <div class="loc-pin-badge">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
      </div>
      <div class="loc-card-body">
        <h3><em>Mesquite</em></h3>
        <p class="addr">3400 I-30 E<br>Mesquite, TX 75150</p>
        <span class="loc-link">Visit location →</span>
      </div>
    </a>

    <a href="/locations/valley-ranch/" class="loc-card fade-in">
      <div class="loc-card-img">
        <img src="/images/loc-valley-ranch.jpg" alt="AymanCare Valley Ranch clinic" loading="lazy">
        <div class="loc-pin-badge">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
      </div>
      <div class="loc-card-body">
        <h3>Valley <em>Ranch</em></h3>
        <p class="addr">10009 N MacArthur Blvd<br>Irving, TX 75063</p>
        <span class="loc-link">Visit location →</span>
      </div>
    </a>
  </div>
</section>

<!-- BIG CTA -->
<section class="big-cta" id="book">
  <div class="big-cta-inner">
    <span class="overline fade-in">◆ Ready when you are</span>
    <h2 class="fade-in">Let's take care<br>of <em>you.</em></h2>
    <p class="fade-in">Book your appointment online in under a minute, or walk into any of our four Dallas-area locations today.</p>
    <div class="cta-row fade-in">
      <a href="/book-online/" class="btn btn-primary">
        Book appointment
        <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <a href="/contact/" class="btn btn-outline">View all locations</a>
    </div>
  </div>
</section>
</Base>
