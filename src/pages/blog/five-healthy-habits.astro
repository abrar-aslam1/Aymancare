<Base
  title="Five habits that actually prevent illness | AymanCare Blog"
  description="Evidence-based prevention advice from AymanCare's board-certified primary care physicians, serving Dallas, North Richland Hills, Mesquite, and Valley Ranch."
>
  <Fragment slot="head">
  <script type="application/ld+json" is:inline set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://aymancare.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://aymancare.com/blog/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Five habits that actually prevent illness\",\"item\":\"https://aymancare.com/blog/five-healthy-habits/\"}]}"} />
